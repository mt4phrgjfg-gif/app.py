from transformers import AutoTokenizer, AutoModelForCausalLM
import torch
import json

# Model yükle
print("Prime Brain başlatılıyor...")
MODEL = "ytu-ce-cosmos/turkish-gpt2"
tokenizer = AutoTokenizer.from_pretrained(MODEL)
model = AutoModelForCausalLM.from_pretrained(MODEL)
tokenizer.pad_token = tokenizer.eos_token
print("Hazır!")

def sohbet_et(mesaj, gecmis=[]):
    # Geçmiş sohbeti birleştir
    gecmis.append(f"Kullanici: {mesaj}")
    giris = "\n".join(gecmis) + "\nPrimeBrain:"
    
    inputs = tokenizer.encode(giris, return_tensors="pt", max_length=512, truncation=True)
    
    with torch.no_grad():
        outputs = model.generate(
            inputs,
            max_new_tokens=150,
            temperature=0.7,
            top_p=0.9,
            top_k=50,
            repetition_penalty=1.3,
            do_sample=True,
            pad_token_id=tokenizer.eos_token_id
        )
    
    yanit = tokenizer.decode(outputs[0], skip_special_tokens=True)
    yanit = yanit.split("PrimeBrain:")[-1].strip()
    yanit = yanit.split("Kullanici:")[0].strip()
    
    gecmis.append(f"PrimeBrain: {yanit}")
    
    # Sohbet geçmişini kaydet
    with open("prime_brain.json", "w", encoding="utf-8") as f:
        json.dump({
            "model": "prime_brain",
            "son_sohbet": gecmis[-10:],
            "durum": "aktif"
        }, f, ensure_ascii=False, indent=2)
    
    return yanit, gecmis

# Sohbet döngüsü
print("\n=== PRIME BRAIN ===")
print("Çıkmak için 'quit' yaz\n")

gecmis = []
while True:
    mesaj = input("Sen: ")
    if mesaj.lower() == "quit":
        print("Prime Brain kapatılıyor...")
        break
    if not mesaj.strip():
        continue
    
    yanit, gecmis = sohbet_et(mesaj, gecmis)
    print(f"Prime Brain: {yanit}\n")
